# editor
export EDITOR="nvim"

# for gpg signing
export GPG_TTY=$(tty)

# Colors
export CLICOLOR=1
export LSCOLORS="ExFxCxDxBxegedabagacad"
## Linux LS_COLORS for zsh completion
export LS_COLORS="di=1;34:ln=1;35:so=1;32:pi=1;33:ex=1;31:bd=34;46:cd=34;43:su=30;41:sg=30;46:tw=30;42:ow=30;43"

# extend history
export HISTSIZE=65536
export SAVEHIST=$HISTSIZE

# Make Python use UTF-8 encoding for output to stdin, stdout, and stderr.
export PYTHONIOENCODING='UTF-8'

# Prefer US English and use UTF-8.
export LANG='en_US.UTF-8'
export LC_ALL='en_US.UTF-8'

# Highlight section titles in manual pages.
export LESS_TERMCAP_md="${yellow}"

# ssh 1pwd sock
export SSH_AUTH_SOCK="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

# ui_arch_auth_github_token
# export GITHUB_REGISTRY_READ_TOKEN="$(cat ~/.config/zerofox/ui_arch_auth_github_token)"
export GITHUB_REGISTRY_WRITE_TOKEN=$GITHUB_REGISTRY_READ_TOKEN

# go
export GOPRIVATE="github.com/riskive"
export GOPATH="$HOME/zerofox/go"

# docker
export COMPOSE_BAKE=true

# brew
export HOMEBREW_UPGRADE_GREEDY=1

# mysql-client
## compilers
export LDFLAGS="-L/opt/homebrew/opt/mysql-client/lib"
export CPPFLAGS="-I/opt/homebrew/opt/mysql-client/include"
## pkgconfig
export PKG_CONFIG_PATH="/opt/homebrew/opt/mysql-client/lib/pkgconfig"

# github
export GH_PAGER=cat
export GITHUB_MCP_TOKEN="$(gh auth token)"
