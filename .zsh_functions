# get jwt token from specified environment (qa or stag)
get-zf-token() {
    local env="$1"

    if [[ -z "$env" ]]; then
        echo "Usage: get-zf-token <qa|stag>"
        return 1
    fi

    # normalize
    env=$(echo "$env" | tr '[:lower:]' '[:upper:]')

    case "$env" in
        QA)
            api_host="https://api-qa.zerofox.com"
            ;;
        STAG)
            api_host="https://api-stag.zerofox.com"
            ;;
        *)
            echo "Invalid environment. Use 'qa' or 'stag'."
            return 1
            ;;
    esac

    curl --silent \
        -d "username=grojas@zerofox.com&password=$(op read "op://Employee/ZeroFOX ${env}/password")" \
        -X POST "${api_host}/auth/token/" \
    | jq -r ".access"
}

# ps + grep
psgrep() {
  local pids
  pids=$(pgrep -f $@)
  if ! [[ $pids ]]; then
    echo "No processes found." >&2; return 1
  fi
  grc ps up $(pgrep -f $@)
}

# Function to fetch paginated GitHub events and format them for standup with color.
# Looks back a specified number of days until 7 AM local time.
# Usage: gh-standup-summary [--debug] [--days N | -d N | --days=N] [--include-commits] [github_username]
#   --debug: Enable verbose debug output to stderr.
#   --days N | -d N | --days=N: Look back N days instead of the default 1 (yesterday).
#   --include-commits: Include commit/push events (default: only PR, tags, releases).
#   github_username: Specify GitHub username (defaults to GITHUB_USER env var or 'grojas_zfox').
gh-standup-summary() {
  # --- Argument Parsing ---
  local debug_mode=0
  local days_back=1 # Default to 1 day (yesterday)
  local include_commits=0 # Default to exclude commits (only show PRs, tags, releases)
  local username=""
  local args_to_process=() # Hold non-flag arguments
  local skip_next=0        # Flag to skip the next argument (used for --days N)

  # Helper function for conditional debug output (defined early for use in parsing)
  _debug_echo() {
    if [[ $debug_mode -eq 1 ]]; then
      # Prepend "DEBUG: " to the message and output to stderr
      echo "DEBUG: $@" >&2
    fi
  }

  # Use a loop with index for easier argument handling like --option value
  for i in {1..$#}; do
    # If the previous iteration told us to skip, do so
    if [[ $skip_next -eq 1 ]]; then
      skip_next=0
      continue
    fi

    local arg="${(P)i}" # Access argument by index (zsh specific)

    case "$arg" in
      --debug)
        debug_mode=1
        _debug_echo "Debug mode enabled." # Announce debug mode ASAP
        ;;
      --days=*) # Handle --days=N format
        local days_value="${arg#--days=}" # Extract value after =
        # Basic validation: check if it's a positive integer
        if [[ "$days_value" =~ ^[1-9][0-9]*$ ]]; then
          days_back="$days_value"
          _debug_echo "Set days_back to $days_back"
        else
          echo "Error: --days= requires a positive integer argument, got '$days_value'." >&2
          return 1
        fi
        ;;
      --days|-d) # Allow -d as a shorthand
        # Check if there is a next argument
        if [[ $((i + 1)) -le $# ]]; then
          local next_arg="${(P)$((i + 1))}"
          # Basic validation: check if it's a positive integer
          if [[ "$next_arg" =~ ^[1-9][0-9]*$ ]]; then
            days_back="$next_arg"
            skip_next=1 # Tell the loop to skip the number argument next time
            _debug_echo "Set days_back to $days_back" # Add debug for this
          else
            echo "Error: --days requires a positive integer argument, got '$next_arg'." >&2
            return 1
          fi
        else
          echo "Error: --days requires an argument (number of days)." >&2
          return 1
        fi
        ;;
      --include-commits)
        include_commits=1
        _debug_echo "Include commits mode enabled."
        ;;
      -*)
        echo "Warning: Unknown option '$arg' ignored." >&2
        ;;
      *)
        # Collect non-flag arguments (expecting username at most)
        args_to_process+=("$arg")
        ;;
    esac
  done

  # Assume the first non-flag argument is the username
  if [[ ${#args_to_process[@]} -gt 0 ]]; then
    username="${args_to_process[1]}" # Zsh arrays are 1-indexed
  fi
  # If more than one non-flag argument was given, warn
  if [[ ${#args_to_process[@]} -gt 1 ]]; then
      echo "Warning: Multiple non-flag arguments provided. Using '${username}' as username. Ignoring others: ${args_to_process[@]:1}" >&2
  fi

  # --- Configuration ---
  # Use parsed username, then GITHUB_USER env var, then default
  local GITHUB_USER="${username:-${GITHUB_USER:-grojas_zfox}}"
  local PER_PAGE=100

  # --- Dependencies Check ---
  if ! command -v jq &> /dev/null; then echo "Error: jq not installed." >&2; return 1; fi
  if ! command -v date &> /dev/null; then echo "Error: date command not found." >&2; return 1; fi
  if ! command -v gh &> /dev/null; then echo "Error: gh CLI not installed." >&2; return 1; fi
  # Ensure zsh/datetime module is loaded for reliable date calculations
  zmodload zsh/datetime &> /dev/null || { echo "Error: zsh/datetime module not loaded. Cannot calculate date reliably." >&2; return 1; }

  # --- Verify gh CLI Authentication ---
  if ! gh auth status &> /dev/null; then
    echo "Error: gh CLI is not authenticated. Please run 'gh auth login' first." >&2
    return 1
  fi
  _debug_echo "gh CLI is authenticated and ready."

  # --- Calculate Target Start Time ---
  local target_start_utc=""
  local target_epoch=""
  local return_status=0

  local now_epoch=$EPOCHSECONDS
  # Calculate seconds since midnight *today* using zsh's strftime
  local seconds_today=$(strftime "%H*3600 + %M*60 + %S" $now_epoch)
  # Calculate epoch for midnight *today*
  local today_midnight_epoch=$((now_epoch - seconds_today))
  _debug_echo "Today midnight epoch: $today_midnight_epoch ($(strftime '%Y-%m-%d %H:%M:%S %Z' $today_midnight_epoch))"

  # Calculate midnight epoch for the target day (N days ago)
  local target_day_midnight_epoch=$((today_midnight_epoch - days_back * 86400))
  _debug_echo "Target day ($days_back days ago) midnight epoch: $target_day_midnight_epoch ($(strftime '%Y-%m-%d %H:%M:%S %Z' $target_day_midnight_epoch))"

  # Calculate the target epoch: Midnight N days ago + 7 hours (7 AM local time)
  target_epoch=$((target_day_midnight_epoch + 7 * 3600))
  _debug_echo "Target epoch ($days_back days ago 7am local): $target_epoch ($(strftime '%Y-%m-%d %H:%M:%S %Z' $target_epoch))"

  # --- Format target epoch to UTC ISO 8601 for GitHub API ---
  # Attempt using 'date' command first (handling GNU vs macOS differences)
  if date --version >/dev/null 2>&1; then # GNU date
     _debug_echo "Using GNU date for formatting."
     target_start_utc=$(date -u -d "@$target_epoch" '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null)
     return_status=$?
  elif [[ "$(uname)" == "Darwin" ]]; then # macOS date
     _debug_echo "Using macOS date for formatting."
     target_start_utc=$(date -u -r "$target_epoch" '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null)
     return_status=$?
  else # Fallback attempt (might work on some other systems)
     _debug_echo "Attempting generic fallback date command for formatting."
     target_start_utc=$(date -u --date="@$target_epoch" '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null)
     return_status=$?
  fi

  # If 'date' command failed or returned empty, try zsh/datetime as a fallback
  if [[ $return_status -ne 0 ]] || [[ -z "$target_start_utc" ]]; then
     _debug_echo "Formatting epoch with 'date' failed (Status: $return_status, Output: '$target_start_utc'). Falling back to zsh/datetime."
     # Use zsh's strftime with -z GMT to force UTC
     target_start_utc=$(strftime -z GMT -s $target_epoch "%Y-%m-%dT%H:%M:%SZ" 2>/dev/null)
     if [[ $? -ne 0 ]] || [[ -z "$target_start_utc" ]]; then
         echo "Error: Failed to format epoch '$target_epoch' to UTC using both 'date' and zsh/datetime." >&2
         return 1
     else
          # Warning only if date failed but strftime worked
          echo "Warning: Used zsh/datetime for final UTC formatting." >&2
     fi
  fi

  # Final check if we successfully got a UTC timestamp
  if [[ -z "$target_start_utc" ]]; then
     echo "Error: Could not determine the target start time in UTC after all attempts." >&2
     return 1
  fi
  _debug_echo "Target start time in UTC: $target_start_utc"
  # --- End Date Calculation ---

  # User-facing info message to stderr
  echo "Fetching events for user '$GITHUB_USER' from the last ${days_back} day(s) (since ${target_start_utc})..." >&2

  # --- Fetching Loop ---
  local page=1
  # Create a temporary file for accumulating events across pages
  local temp_events_file=$(mktemp "${TMPDIR:-/tmp}/github_events.XXXXXX")
  # Declare response_file here so trap can see it even if loop doesn't run
  local response_file=""
  # Ensure temp files are cleaned up on exit, interrupt, termination, or hangup
  # The &> /dev/null suppresses errors if a file doesn't exist (e.g., if API call failed before creating response_file)
  trap 'rm -f "$temp_events_file" "$response_file" &> /dev/null' EXIT INT TERM HUP

  while true; do
    _debug_echo -n "Fetching page $page... "
    # Create a new temp file for each page's response
    response_file=$(mktemp "${TMPDIR:-/tmp}/github_page.XXXXXX")

    # Fetch the page from GitHub API using gh api
    # gh api automatically handles the correct hostname (github.com or enterprise) and authentication
    if ! gh api "/users/${GITHUB_USER}/events?per_page=${PER_PAGE}&page=${page}" > "$response_file" 2>&1; then
      echo "\nError: GitHub API request failed for page $page." >&2
      # Show API error message from the response file
      cat "$response_file" >&2
      rm -f "$response_file" # Clean up this page's temp file immediately
      # Trap will clean up $temp_events_file
      return 1
    fi

    # Validate if the response is a JSON array before processing
    if ! jq -e '. | type == "array"' "$response_file" > /dev/null 2>&1; then
        echo "\nError: Invalid JSON array received for page $page. Response:" >&2
        cat "$response_file" >&2 # Show the invalid response
        rm -f "$response_file"
        return 1
    fi

    local events_count=$(jq 'length' "$response_file")
    _debug_echo "$events_count events."

    # If this page is empty, we're done fetching
    if [[ "$events_count" -eq 0 ]]; then
        _debug_echo "Fetched page $page with 0 events. Assuming end of data."
        rm -f "$response_file" # Clean up empty page file
        break # No more events on this page or subsequent pages
    fi

    # Append each event object from the current page's array to the main temp file, one JSON object per line
    jq -c '.[]' "$response_file" >> "$temp_events_file"

    # Check the timestamp of the *last* event fetched on this page
    # Use jq -r to get the raw string value
    local last_event_ts=$(jq -r '.[-1].created_at' "$response_file")

    # Clean up the temp file for the current page *after* using it
    rm -f "$response_file"
    response_file="" # Reset variable so trap doesn't try to remove it again

    # If the last event on the page is older than our target, we can stop fetching subsequent pages
    # Note: Timestamps are ISO8601 strings, lexicographical comparison works correctly
    if [[ -n "$last_event_ts" && "$last_event_ts" < "$target_start_utc" ]]; then
      _debug_echo "Reached events older than target start time ($last_event_ts < $target_start_utc). Stopping fetch."
      break
    fi

    # If we received fewer events than requested per page, it must be the last page
    if [[ "$events_count" -lt "$PER_PAGE" ]]; then
        _debug_echo "Fetched last page ($events_count events < $PER_PAGE)."
        break
    fi

    ((page++))
    # sleep 0.2 # Optional: Be nice to the API if making many requests
  done

  # --- Process Collected Events ---
  _debug_echo "Processing collected events from $temp_events_file..."
  # Check if the main temporary file exists and is not empty
  if [[ ! -s "$temp_events_file" ]]; then
    echo "No relevant events found for '$GITHUB_USER' since $target_start_utc." >&2
    # Trap will clean up the empty file
    return 0
  fi

  # --- JQ Filter Definition ---
  # First pass: Extract PR events that need titles fetched
  local pr_fetch_filter
  pr_fetch_filter=$(cat <<- 'EOF'
  map(select(.created_at >= $target_start_utc and .type == "PullRequestEvent")) |
  map({
    repo: .repo.name,
    number: .payload.number,
    key: "\(.repo.name)#\(.payload.number)"
  }) |
  unique_by(.key) |
  .[]
EOF
)

  # Fetch PR titles and store in a temporary file
  local pr_titles_file=$(mktemp "${TMPDIR:-/tmp}/pr_titles.XXXXXX")
  trap 'rm -f "$temp_events_file" "$response_file" "$pr_titles_file" &> /dev/null' EXIT INT TERM HUP

  _debug_echo "Fetching PR titles..."
  # Extract unique PR events and fetch their titles
  # Use -c for compact output (each JSON object on a single line)
  jq -s -c --arg target_start_utc "$target_start_utc" "$pr_fetch_filter" < "$temp_events_file" | while IFS= read -r pr_event; do
    if [[ -n "$pr_event" ]] && [[ "$pr_event" != "null" ]]; then
      local pr_repo=$(echo "$pr_event" | jq -r '.repo')
      local pr_number=$(echo "$pr_event" | jq -r '.number')
      local pr_key=$(echo "$pr_event" | jq -r '.key')
      
      _debug_echo "  Fetching title and description for $pr_key..."
      # Fetch PR title and body using gh api, add the key field directly in jq to avoid shell escaping issues
      gh api "/repos/${pr_repo}/pulls/${pr_number}" 2>/dev/null | \
        jq --arg key "$pr_key" '{key: $key, title: .title, body: .body}' >> "$pr_titles_file" || \
        jq -n --arg key "$pr_key" '{key: $key, title: "", body: ""}' >> "$pr_titles_file"
    fi
  done

  # Main JQ Filter with PR title and description lookup
  local final_jq_filter
  final_jq_filter=$(cat <<- 'EOF'
  # Load PR data (title and body) into lookup objects
  ($pr_titles | map({key: .key, value: {title: .title, body: .body}}) | from_entries) as $pr_data_map |
  
  # Input is the combined array using -s flag
  # Step 1: Filter the entire array by date first. map() iterates over the input array.
  map(select(.created_at >= $target_start_utc)) |

  # Step 2: Process relevant events from the filtered array into structured objects {repo, summary}. map() iterates again.
  map(
    # Select only the event types we care about formatting
    # PushEvent is conditionally included based on $include_commits flag
    select(
      ($include_commits == "1" and .type == "PushEvent") or
      .type == "PullRequestEvent" or
      .type == "CreateEvent" or
      .type == "DeleteEvent" or
      .type == "ReleaseEvent"
    ) |
    # Store timestamp and repo name
    (.created_at) as $timestamp |
    (.repo.name) as $repo |
    # Format based on event type
    if .type == "PushEvent" then
      (.payload.ref | split("/") | .[-1]) as $branch |
      (.payload.commits[0]?.message // "(commit message unavailable)") as $message |
      (.payload.commits[0]?.sha[0:7] // "-------") as $sha |
      {repo: $repo, summary: "\u001b[90m\($timestamp)\u001b[0m \u001b[32m\u001b[1mPUSH\u001b[0m    to (\u001b[36m\($branch)\u001b[0m): \(.payload.size) commit(s) (latest: \"\($message)\" - \u001b[90m\($sha)\u001b[0m)"}
    elif .type == "PullRequestEvent" then
      (.payload.action) as $action |
      (if $action == "opened" then "\u001b[33m" elif $action == "closed" or $action == "merged" then "\u001b[35m" else "\u001b[34m" end) as $pr_color |
      ("\($repo)#\(.payload.number)") as $pr_key |
      ($pr_data_map[$pr_key] // {title: "Title unavailable", body: ""}) as $pr_data |
      ($pr_data.title) as $pr_title |
      ($pr_data.body // "") as $pr_body |
      # Format PR with description only for "opened" action
      if $action == "opened" and $pr_body != "" and $pr_body != "null" then
        # Split body into lines and indent each line
        ($pr_body | split("\n") | map("         \u001b[90m" + . + "\u001b[0m") | join("\n")) as $pr_body_formatted |
        {repo: $repo, summary: "\u001b[90m\($timestamp)\u001b[0m \($pr_color)\u001b[1mPR\u001b[0m      \($pr_color)\($action)\u001b[0m: #\(.payload.number) \"\($pr_title)\"\n\($pr_body_formatted)"}
      else
        {repo: $repo, summary: "\u001b[90m\($timestamp)\u001b[0m \($pr_color)\u001b[1mPR\u001b[0m      \($pr_color)\($action)\u001b[0m: #\(.payload.number) \"\($pr_title)\""}
      end
    elif .type == "CreateEvent" then
      {repo: $repo, summary: "\u001b[90m\($timestamp)\u001b[0m \u001b[34m\u001b[1mCREATE\u001b[0m  \(.payload.ref_type): \u001b[36m\(.payload.ref // "N/A")\u001b[0m"}
    elif .type == "DeleteEvent" then
      {repo: $repo, summary: "\u001b[90m\($timestamp)\u001b[0m \u001b[31m\u001b[1mDELETE\u001b[0m  \(.payload.ref_type): \u001b[36m\(.payload.ref // "N/A")\u001b[0m"}
    elif .type == "ReleaseEvent" then
      (.payload.release.name // "") as $release_name |
      (.payload.release.tag_name // "N/A") as $tag_name |
      if $release_name != "" and $release_name != $tag_name then
        {repo: $repo, summary: "\u001b[90m\($timestamp)\u001b[0m \u001b[35m\u001b[1mRELEASE\u001b[0m published: \u001b[33m\($tag_name)\u001b[0m (\($release_name))"}
      else
        {repo: $repo, summary: "\u001b[90m\($timestamp)\u001b[0m \u001b[35m\u001b[1mRELEASE\u001b[0m published: \u001b[33m\($tag_name)\u001b[0m"}
      end
    else
      # This case should technically not be reached due to the initial select, but good practice
      empty
    end
  ) | # End the map for transformation

  # Step 3: Group the resulting array of {repo, summary} objects by repo name
  group_by(.repo) |

  # Step 4: Format the output for each group (iterating over the array of groups)
  .[] | # Iterate through each group array
  # Header: Bold Blue repo name
  "--- \u001b[1m\u001b[34m\(.[0].repo)\u001b[0m ---",
  # Print the summary string for each event in the group
  (.[].summary),
  # Print a blank line after each group
  ""
EOF
)

  # --- Execute JQ ---
  # Use jq with --arg to pass the calculated UTC start time and include_commits flag.
  # Use --slurpfile to load PR titles into a variable.
  # Use -s (--slurp) to read all JSON objects from the file into one large array.
  # Use -r (--raw-output) to get plain text lines instead of JSON strings.
  # Input is redirected from the accumulated temporary events file.
  if ! jq -s -r --arg target_start_utc "$target_start_utc" --arg include_commits "$include_commits" --slurpfile pr_titles "$pr_titles_file" "$final_jq_filter" < "$temp_events_file"; then
      echo "Error: jq processing failed. Check filter logic or input data in $temp_events_file (if --debug was used)." >&2
      # Keep the temp file if debug is on and jq fails, otherwise the trap cleans it.
      if [[ $debug_mode -eq 0 ]]; then
         _debug_echo "JQ failed and not in debug mode, removing $temp_events_file"
         rm -f "$temp_events_file" "$pr_titles_file"
      else
         _debug_echo "JQ failed in debug mode, leaving $temp_events_file and $pr_titles_file for inspection."
      fi
      # Reset trap to default behavior now that we've handled potential error cleanup
      trap - EXIT INT TERM HUP
      return 1
  fi

  _debug_echo "Processing complete."
  # Trap automatically cleans up $temp_events_file on successful exit
  # Reset trap explicitly after successful completion.
  trap - EXIT INT TERM HUP
  return 0 # Explicitly return success
}

# rotate ~/tmp dir
function rotate-tmp() {
  rm -rf ~/tmp
  mkdir ~/tmp
  echo 'Succesfully rotated ~/tmp dir'
}

# Checks if currently authenticated with npm; logs in only if necessary.
function npm-auth() {
  if npm whoami > /dev/null 2>&1; then
    echo "✅ Already logged in as $(npm whoami)"
  else
    echo "🔑 Not logged in. Starting login..."
    npm login --auth-type=web --force
  fi
}

# Cleans local git branches excluding main, master, development, and the current branch.
# Usage: 
#   git-branch-clean         -> Safe delete (git branch -d)
#   git-branch-clean -f      -> Force delete (git branch -D)
function git-branch-clean() {
    local flag="-d" 
    
    if [[ "$1" == "-f" || "$1" == "--force" ]]; then
        flag="-D"
        echo "🚨 Running FORCE clean..."
    else
        echo "🧹 Running SAFE clean..."
    fi

    git branch | grep -v "main\|master\|development\|*" | xargs git branch $flag
    git pull --prune
}

# Session-level env bootstrap from 1Password:
# reuses launchd value when available; otherwise reads once via `op read`, caches in launchd, and exports.
# Usage: ensure_op_env VAR_NAME 'op://vault/item/field'
ensure_op_env() {
  [[ -o interactive ]] || return 0

  local env_var="$1"
  local op_path="$2"
  local value=""

  if [[ -z "$env_var" || -z "$op_path" ]]; then
    print -u2 "[ERROR] Usage: ensure_op_env VAR_NAME 'op://vault/item/field'"
    return 1
  fi

  # Already set in this shell
  value="${(P)env_var}"
  if [[ -n "$value" ]]; then
    export "$env_var"
    return 0
  fi

  # Fast path: reuse cached value from launchd
  value="$(launchctl getenv "$env_var" 2>/dev/null)"

  # Slow path: fetch once from 1Password (may fail if locked/not running)
  if [[ -z "$value" ]]; then
    value="$(op read "$op_path" 2>/dev/null)" || true
    if [[ -z "$value" ]]; then
      print -u2 "[ERROR] ${env_var} not set (1Password locked/not available). Run: op read '$op_path'"
      return 1
    fi
    launchctl setenv "$env_var" "$value"
  fi

  export "$env_var=$value"
}


# Logs into all configured Codex MCP servers by parsing `codex mcp list --json`
cx-mcp-login-all() {
  local delay=0.1
  local servers
  servers=($(codex mcp list --json \
    | jq -r '.[] 
      | select(.enabled == true and .auth_status != "unsupported") 
      | .name'))

  if [[ ${#servers[@]} -eq 0 ]]; then
    echo "No MCP servers found in configuration."
    return
  fi

  for srv in "${servers[@]}"; do
    echo "Logging in to MCP server: $srv"
    codex mcp login "$srv"
    echo "Waiting ${delay}s before next login..."
    sleep "$delay"
  done
}

# vt-db: prints params used + MySQL connection string and copies URL to clipboard; defaults to --env qa --filter monolith-db --role all-readonly
vt-db() {
  local env="qa"
  local filter="monolith-db"
  local role="all-readonly"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --env=*)    env="${1#*=}"; shift ;;
      --env)      env="$2"; shift 2 ;;
      --filter=*) filter="${1#*=}"; shift ;;
      --filter|-f) filter="$2"; shift 2 ;;
      --role=*)   role="${1#*=}"; shift ;;
      --role)     role="$2"; shift 2 ;;
      *) echo "Unknown flag: $1" >&2; return 1 ;;
    esac
  done

  echo "env=$env filter=$filter role=$role"

  vt database login --env "$env" -f "$filter" --role "$role" --format json \
  | jq -r '"mysql://\(.Username|@uri):\(.Password|@uri)@\(.Address)"' \
  | tee >(pbcopy)
}


svg2png() {
  local in="$1"
  local scale="${2:-4}"
  local out

  [[ -n "$in" ]] || { echo "usage: svg2png input.svg [scale]" >&2; return 1; }
  [[ -f "$in" ]] || { echo "file not found: $in" >&2; return 1; }
  [[ "$in" == *.svg ]] || { echo "input must be an .svg file" >&2; return 1; }

  out="${in%.svg}.png"
  rsvg-convert -f png -b white -z "$scale" "$in" -o "$out" || return 1
  printf '%s\n' "$out"
}

mermaid2png() {
  local out="${1:-mermaid-$(date +%Y%m%d-%H%M%S).png}"
  local scale="${2:-9}"
  local background="#1e1e1e"
  local raw mermaid tmp_input tmp_config tmp_css browser_path

  raw="$(pbpaste)"
  raw="${raw//$'\r'/}"

  [[ -n "$raw" ]] || { echo "clipboard is empty" >&2; return 1; }
  [[ "$out" == *.png ]] || out="${out}.png"

  if [[ "$raw" == *'```mermaid'* ]]; then
    mermaid="$(printf '%s\n' "$raw" | awk '
      /^[[:space:]]*```mermaid([[:space:]].*)?$/ { in_block=1; next }
      in_block && /^[[:space:]]*```[[:space:]]*$/ { exit }
      in_block { print }
    ')"
    [[ -n "$mermaid" ]] || { echo "no mermaid block found in clipboard" >&2; return 1; }
  else
    mermaid="$raw"
  fi

  tmp_input="$(mktemp "${TMPDIR:-/tmp}/mermaid2png.XXXXXX.mmd")" || return 1
  printf '%s\n' "$mermaid" > "$tmp_input" || { rm -f "$tmp_input"; return 1; }
  tmp_config="$(mktemp "${TMPDIR:-/tmp}/mermaid2png.XXXXXX.json")" || { rm -f "$tmp_input"; return 1; }
  tmp_css="$(mktemp "${TMPDIR:-/tmp}/mermaid2png.XXXXXX.css")" || { rm -f "$tmp_input" "$tmp_config"; return 1; }
  printf '%s\n' \
    '{' \
    '  "theme": "base",' \
    '  "themeVariables": {' \
    '    "darkMode": true,' \
    '    "background": "#1e1e1e",' \
    '    "primaryColor": "#2a3950",' \
    '    "primaryBorderColor": "#8ab4f8",' \
    '    "primaryTextColor": "#e6edf7",' \
    '    "secondaryColor": "#1f3d46",' \
    '    "secondaryBorderColor": "#5fb3c4",' \
    '    "secondaryTextColor": "#e6edf7",' \
    '    "tertiaryColor": "#314332",' \
    '    "tertiaryBorderColor": "#7fb77e",' \
    '    "tertiaryTextColor": "#e6edf7",' \
    '    "mainBkg": "#2a3950",' \
    '    "secondBkg": "#1f3d46",' \
    '    "tertiaryBkg": "#314332",' \
    '    "clusterBkg": "#23313d",' \
    '    "clusterBorder": "#5d77a3",' \
    '    "lineColor": "#8ab4f8",' \
    '    "defaultLinkColor": "#8ab4f8",' \
    '    "edgeLabelBackground": "#23313d",' \
    '    "textColor": "#e6edf7",' \
    '    "titleColor": "#e6edf7",' \
    '    "nodeBorder": "#8ab4f8",' \
    '    "actorBkg": "#2a3950",' \
    '    "actorBorder": "#8ab4f8",' \
    '    "actorLineColor": "#5d77a3",' \
    '    "actorTextColor": "#e6edf7",' \
    '    "signalColor": "#8ab4f8",' \
    '    "signalTextColor": "#e6edf7",' \
    '    "labelBoxBkgColor": "#1f3d46",' \
    '    "labelBoxBorderColor": "#5fb3c4",' \
    '    "activationBkgColor": "#1f3d46",' \
    '    "activationBorderColor": "#8ab4f8",' \
    '    "sequenceNumberColor": "#e6edf7",' \
    '    "noteBkgColor": "#233b44",' \
    '    "noteBorderColor": "#5fb3c4",' \
    '    "noteTextColor": "#e6edf7"' \
    '  }' \
    '}' > "$tmp_config" || { rm -f "$tmp_input" "$tmp_config" "$tmp_css"; return 1; }
  printf '%s\n' \
    '.actor.actor-top, .actor.actor-bottom {' \
    '  fill: #2a3950 !important;' \
    '  stroke: #8ab4f8 !important;' \
    '}' \
    '.actor-line {' \
    '  stroke: #5d77a3 !important;' \
    '}' \
    'text.actor > tspan, .messageText, .messageText tspan, .labelText, .labelText tspan, .noteText, .noteText tspan {' \
    '  fill: #e6edf7 !important;' \
    '}' \
    '#sequencenumber circle {' \
    '  fill: #1f3d46 !important;' \
    '  stroke: #8ab4f8 !important;' \
    '}' \
    '.sequenceNumber {' \
    '  fill: #e6edf7 !important;' \
    '}' \
    '.activation0, .activation1, .activation2 {' \
    '  fill: #1f3d46 !important;' \
    '  stroke: #8ab4f8 !important;' \
    '}' > "$tmp_css" || { rm -f "$tmp_input" "$tmp_config" "$tmp_css"; return 1; }

  if [[ -z "$PUPPETEER_EXECUTABLE_PATH" ]]; then
    for browser_path in \
      "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" \
      "/Applications/Chromium.app/Contents/MacOS/Chromium" \
      "/Applications/Brave Browser.app/Contents/MacOS/Brave Browser" \
      "/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge"
    do
      [[ -x "$browser_path" ]] && break
      browser_path=""
    done
  else
    browser_path="$PUPPETEER_EXECUTABLE_PATH"
  fi

  [[ -n "$browser_path" ]] || {
    rm -f "$tmp_input" "$tmp_config" "$tmp_css"
    echo "no Chrome-compatible browser found for mermaid-cli" >&2
    return 1
  }

  PUPPETEER_EXECUTABLE_PATH="$browser_path" \
    mmdc -q -i "$tmp_input" -o "$out" -e png -s "$scale" -b "$background" -c "$tmp_config" -C "$tmp_css" || { rm -f "$tmp_input" "$tmp_config" "$tmp_css"; return 1; }
  rm -f "$tmp_input" "$tmp_config" "$tmp_css"

  printf '%s\n' "$out"
}
