# Keep tmux's VIRTUAL_ENV in sync with the current shell.
_tmux_update_virtual_env() {
    [[ -n "$TMUX" ]] || return

    if [[ -n "$VIRTUAL_ENV" ]]; then
        tmux set-environment VIRTUAL_ENV "$VIRTUAL_ENV"
    else
        tmux set-environment -u VIRTUAL_ENV
    fi
}

