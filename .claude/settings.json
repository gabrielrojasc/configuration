{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Read",
      "Bash(gh auth status)",
      "Bash(gh * list *)",
      "Bash(gh * view *)",
      "Bash(gh search *)",
      "Bash(gh api user*)",
      "Bash(gh api \"user*\")",
      "Bash(gh api rate_limit*)",
      "Bash(gh api \"rate_limit*\")",
      "Bash(gh api /rate_limit*)",
      "Bash(gh api \"/rate_limit*\")",
      "Bash(gh api orgs/*)",
      "Bash(gh api \"orgs/*\")",
      "Bash(gh api repos/*/issues*)",
      "Bash(gh api \"repos/*/issues*\")",
      "Bash(gh api repos/*/pulls*)",
      "Bash(gh api \"repos/*/pulls*\")",
      "Bash(gh api repos/*/commits*)",
      "Bash(gh api \"repos/*/commits*\")",
      "Bash(gh api /repos/*/commits*)",
      "Bash(gh api \"/repos/*/commits*\")",
      "Bash(gh api repos/*/releases*)",
      "Bash(gh api \"repos/*/releases*\")",
      "Bash(gh api /repos/*/releases*)",
      "Bash(gh api \"/repos/*/releases*\")",
      "Bash(gh api repos/*/actions/workflows*)",
      "Bash(gh api \"repos/*/actions/workflows*\")",
      "Bash(gh api /repos/*/actions/workflows*)",
      "Bash(gh api \"/repos/*/actions/workflows*\")",
      "Bash(gh api repos/*/actions/runs*)",
      "Bash(gh api \"repos/*/actions/runs*\")",
      "Bash(gh api /repos/*/actions/runs*)",
      "Bash(gh api \"/repos/*/actions/runs*\")",
      "Bash(gh api repos/*/contents*)",
      "Bash(gh api \"repos/*/contents*\")",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git remote -v)",
      "Bash(git rev-parse *)",
      "Bash(git describe *)",
      "Bash(git ls-files *)",
      "Bash(git grep *)",
      "Bash(git blame *)",
      "Bash(git reflog *)",
      "Bash(git stash list)",
      "Bash(git tag *)",
      "Bash(git config --get *)",
      "Bash(git config --list)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git add *)",
      "Bash(git stash push *)",
      "Bash(git stash pop)",
      "Bash(git stash apply *)",
      "Bash(git stash drop *)",
      "Bash(git stash show *)",
      "Bash(git restore --staged *)",
      "Bash(git restore *)",
      "Bash(xargs cat:*)"
    ],
    "deny": [
      "Bash(gh * create *)",
      "Bash(gh * edit *)",
      "Bash(gh * delete *)",
      "Bash(gh * close *)",
      "Bash(gh * reopen *)",
      "Bash(gh * merge *)",
      "Bash(gh * review *)",
      "Bash(gh * comment *)",
      "Bash(gh * ready *)",
      "Bash(gh * lock *)",
      "Bash(gh * unlock *)",
      "Bash(gh api -X POST *)",
      "Bash(gh api --method POST *)",
      "Bash(gh api -X PUT *)",
      "Bash(gh api --method PUT *)",
      "Bash(gh api -X PATCH *)",
      "Bash(gh api --method PATCH *)",
      "Bash(gh api -X DELETE *)",
      "Bash(gh api --method DELETE *)",
      "Bash(git push *)",
      "Bash(git push --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset *)",
      "Bash(git clean *)",
      "Bash(git rebase *)",
      "Bash(git merge *)",
      "Bash(git cherry-pick *)",
      "Bash(git revert *)",
      "Bash(git am *)",
      "Bash(git apply *)",
      "Bash(git bisect *)",
      "Bash(git worktree *)",
      "Bash(git submodule *)",
      "Bash(git checkout -f *)",
      "Bash(git switch -f *)",
      "Bash(git restore --source *)",
      "Bash(git stash clear)",
      "Bash(git stash branch *)",
      "Bash(git branch -d *)",
      "Bash(git branch -D *)",
      "Bash(git tag -d *)",
      "Bash(git config *)"
    ]
  },
  "model": "best",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 1
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": ["*"]
    }
  },
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "auto-update": "stable",
  "skipAutoPermissionPrompt": true
}
