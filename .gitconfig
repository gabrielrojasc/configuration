[user]
    name = Gabriel Rojas
    email = gabo06123@gmail.com
    signingkey = /Users/gabriel/.ssh/id_ed25519_signing.pub


[gpg]
    format = ssh

[gpg "ssh"]
    allowedSignersFile = /Users/gabriel/.ssh/allowed_signers

[commit]
    gpgsign = true

[tag]
    gpgsign = true

[init]
    defaultBranch = main

[pull]
    rebase = true

[rebase]
    autostash = true
    autosquash = true

[credential]
    username = gabo06123@gmail.com

[push]
    autoSetupRemote = true

[pager]
# Use `diff-highlight`
    log = diff-highlight | less
    show = diff-highlight | less
    diff = diff-highlight | less

[merge]
    conflictStyle = zdiff3

[rerere]
    enabled = true

[diff]
    algorithm = histogram
    colorMoved = default

[branch]
    sort = -committerdate

[color]
    ui = auto

[url "ssh://git@github.com/"]
    insteadOf = https://github.com/
