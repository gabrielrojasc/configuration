[user]
  name = Gabriel Rojas
  email = grojas@zerofox.com
  signingkey = 29F3609CCAA1522E32791E56A4E9D5C4F1799165

[color]
  status = auto
  branch = auto
  interactive = auto
  diff = auto
  grep = auto
  ui = auto

[commit]
  gpgsign = true
  template = /Users/grojas/.gitmessage
	verbose = true

[tag]
  gpgsign = true
  sort = version:refname

[init]
  defaultBranch = master

[pull]
  rebase = true

[rebase]
	autoStash = true
	autoSquash = true
	updateRefs = true

[credential]
  username = grojas@zerofox.com

[push]
  autoSetupRemote = true
	followTags = true

[pager]
  # Use `diff-highlight`
  log = diff-highlight | less
  show = diff-highlight | less
  diff = diff-highlight | less

[merge]
  conflictStyle = zdiff3

[rerere]
  enabled = true
	autoupdate = true

[diff]
  algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true
	renames = true

[branch]
  sort = -committerdate

[core]
  excludesFile = /Users/grojas/.gitignore_global

[column]
  ui = auto

[fetch]
	pruneTags = true
	all = true

[url "ssh://git@github.com/"]
  insteadOf = https://github.com/

[includeIf "gitdir:~/fun/"]
  path = ~/fun/.gitconfig
